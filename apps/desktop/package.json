{
  "name": "@apps/desktop",
  "private": true,
  "version": "1.0.22",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dev:prod": "electron-vite preview",
    "dev:prod:localdb": "electron-vite preview",
    "dist": "pnpm run build && electron-builder",
    "dist:win": "pnpm run build && electron-builder --win nsis",
    "dist:win:publish": "pnpm run build && electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "@site-parser/shared": "workspace:*",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "5.4.21"
  },
  "build": {
    "appId": "com.siteparser.app",
    "productName": "GermanyDrive Site Parser",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "npmRebuild": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kazachenka",
        "repo": "GermanyDrive-site-parser"
      }
    ]
  }
}